# ==============================================================================
# STM32CubeIDE .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# STM32CubeIDE — IDE files
# ------------------------------------------------------------------------------
.cproject
.mxproject
.project
.settings/
STM32Make.make

# ------------------------------------------------------------------------------
# Build output
# ------------------------------------------------------------------------------
Debug/
Release/
build/

# ------------------------------------------------------------------------------
# ST auto-generated code (CubeMX)
# ------------------------------------------------------------------------------
Drivers/
Middlewares/

# ------------------------------------------------------------------------------
# Linker & startup files (auto-generated by CubeMX)
# ------------------------------------------------------------------------------
*.ld
startup_*.s

# ------------------------------------------------------------------------------
# Binary & object output
# ------------------------------------------------------------------------------
*.o
*.d
*.elf
*.bin
*.hex
*.map
*.lst
*.su

# ------------------------------------------------------------------------------
# Eclipse / CDT workspace files
# ------------------------------------------------------------------------------
.metadata/
RemoteSystemsTempFiles/
*.launch

# ------------------------------------------------------------------------------
# Windows
# ------------------------------------------------------------------------------
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------------------------
# macOS
# ------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ------------------------------------------------------------------------------
# Linux
# ------------------------------------------------------------------------------
*~
.fuse_hidden*
.Trash-*

# ------------------------------------------------------------------------------
# Backup files
# ------------------------------------------------------------------------------
*.bak
*.orig
*.swp
*.swo